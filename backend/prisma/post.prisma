model Post {
    id           String    @id @default(uuid()) @db.Uuid()
    imageExt     String    @db.VarChar(4)
    creationDate DateTime  @default(now())
    updatedAt    DateTime?
    isEdited     Boolean   @default(false)
    type         PostType  @default(OTHER)
    title        String    @db.VarChar(64)
    description  String?   @db.VarChar(280)
    audio        String?
    audioDuration Int?

    nbLikes    Int @default(0)
    nbComments Int @default(0)

    likes    Like[]
    comments Comment[]
    reports  Report[]
    notifications Notification[]
    postTags PostTag[]

    localisationId Int
    Localisation   Localisation @relation(fields: [localisationId], references: [id], onDelete: Cascade)

    groupId Int?
    Group   Group? @relation(fields: [groupId], references: [id], onDelete: Restrict)

    userId Int
    User   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([creationDate(sort: Desc), id(sort: Desc)])
}


enum PostType {
    PANORAMA           // Points de vue, belvédères, spots photo
    HISTORIC_SITE      // Monuments, châteaux, ruines
    NATURAL_AREA       // Parcs, forêts, montagnes, sentiers
    COASTAL_WATER      // Plages, cascades, lacs, rivières
    URBAN_ARCHITECTURE // Places célèbres, quartiers iconiques, design
    GASTRONOMY         // Restaurants typiques, marchés, street-food
    UNIQUE_STAY        // Hôtels insolites, glamping, cabanes
    ART_CULTURE        // Musées, street-art, galeries
    NIGHTLIFE          // Rooftops, bars conceptuels, clubs
    HIDDEN_GEM         // Lieux secrets, hors des sentiers battus
    OTHER              // Autres
}



model Tag {
    id    Int       @id @default(autoincrement())
    name  String    @unique

    nbUses Int @default(0)

    posts     PostTag[]
    followers TagFollow[]
    notifications Notification[]
}



model PostTag {
    postId String @db.Uuid()
    tagId  Int
    post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
    tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

    @@id([postId, tagId])
}



model Localisation {
    id    Int       @id @default(autoincrement())
    name  String    @unique
    long  Float
    lat   Float

    nbUses Int @default(0)

    posts         Post[]
    followers     LocalisationFollow[]
    notifications Notification[]
}



model Like {
    id Int @id @default(autoincrement())

    postId String @db.Uuid()
    Post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

    userId Int?
    User   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

    anonymousUserId String? @db.Uuid()
}



model Comment {
    id           Int       @id @default(autoincrement())
    content      String    @db.VarChar(280)
    creationDate DateTime  @default(now())
    updatedAt    DateTime?
    isEdited     Boolean   @default(false)

    nbLikes   Int @default(0)
    nbReplies Int @default(0)

    postId String @db.Uuid()
    Post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

    userId Int
    User   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    parentId Int?
    parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)

    commentLikes CommentLike[]
    comments Comment[] @relation("CommentReplies")
}



model CommentLike {
    id Int @id @default(autoincrement())

    commentId Int
    Comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

    userId Int?
    User   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

    anonymousUserId String? @db.Uuid()
}



model Report {
    creationDate DateTime     @default(now())
    reason       ReportReason
    details      String?      @db.VarChar(300)

    postId String @db.Uuid()
    Post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

    userId Int
    User   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([postId, userId])
}



enum ReportReason {
    INNAPROPRIATE_CONTENT
    WRONG_LOCALISATION
    SPAM
    PRIVATE_LIFE_VIOLATION
    DANGEROUS_INFORMATIONS
    OTHER
}