model Trip {
    id           Int       @id @default(autoincrement())
    creationDate DateTime  @default(now())
    price        Int
    durationTime Int
    categorie    TripCategory
    difficulty   Int?

    nbLikes     Int @default(0)
    nbBookmarks Int @default(0)

    userId Int
    User   User @relation(fields: [userId], references: [id], onDelete: Cascade)

    tripSteps     TripStep[]
    tripBookmarks TripBookmark[]
    tripLikes     TripLike[]
}



model TripStep {
    tripId Int
    postId String @db.Uuid()

    stepNumber Int

    Trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
    Post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

    @@id([tripId, postId])
}



model TripBookmark {
    tripId Int
    userId Int

    Trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
    User   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([tripId, userId])
}



model TripLike {
    tripId Int
    userId Int

    Trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
    User   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([tripId, userId])
}



enum TripCategory {
    NORMAL
    BUISNESS
}