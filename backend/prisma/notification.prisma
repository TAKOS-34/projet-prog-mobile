model Notification {
    id           Int              @id @default(autoincrement())
    type         NotificationType
    creationDate DateTime         @default(now())
    isRead       Boolean          @default(false)

    targetUserId Int
    targetUser   User @relation("NotificationTargetUser", fields: [targetUserId], references: [id], onDelete: Cascade)

    targetPostId String @db.Uuid()
    post         Post   @relation(fields: [targetPostId], references: [id])

    targetGroupId Int?
    group        Group? @relation(fields: [targetGroupId], references: [id])

    targetTagId Int?
    tag         Tag? @relation(fields: [targetTagId], references: [id])

    userId Int
    User   User @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId, creationDate(sort: Desc), id(sort: Desc)])
}



enum NotificationType {
    NEW_POST_USER
    NEW_POST_GROUP
    NEW_POST_TAG
}
