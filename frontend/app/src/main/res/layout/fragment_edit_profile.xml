<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp">

        <ImageView
            android:id="@+id/btnBack"
            style="@style/Widget.TravelApp.Icon.Back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvEditTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Modifier le profil"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.TravelApp.HeadlineMedium"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvEditSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Personnalisez votre carnet de voyage."
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/tvEditTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutAvatar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tvEditSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatarEdit"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:scaleType="centerCrop"
                android:background="#D1D5DB"
                app:shapeAppearanceOverlay="@style/Widget.TravelApp.Avatar"
                tools:src="@tools:sample/avatars"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="-8dp"
                android:layout_marginBottom="-8dp"
                app:fabSize="mini"
                app:backgroundTint="@color/primary"
                app:tint="@android:color/white"
                android:src="@android:drawable/ic_menu_edit"
                app:layout_constraintBottom_toBottomOf="@id/ivAvatarEdit"
                app:layout_constraintEnd_toEndOf="@id/ivAvatarEdit" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tvLoginLabel"
            style="@style/Widget.TravelApp.TextView.InputLabel"
            android:text="LOGIN/USERNAME"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/layoutAvatar"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilLogin"
            style="@style/Widget.TravelApp.TextInputLayout.Line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/tvLoginLabel">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLogin"
                style="@style/Widget.TravelApp.TextInputEditText.Line"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="elena_adventurer" />
        </com.google.android.material.textfield.TextInputLayout>

        <View style="@style/Widget.TravelApp.View.Divider"
            app:layout_constraintTop_toBottomOf="@id/tilLogin" />

        <TextView
            android:id="@+id/tvEmailLabel"
            style="@style/Widget.TravelApp.TextView.InputLabel"
            android:text="EMAIL"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tilLogin"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEmail"
            style="@style/Widget.TravelApp.TextInputLayout.Line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/tvEmailLabel">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEmail"
                style="@style/Widget.TravelApp.TextInputEditText.Line"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="elena.travels@gmail.com" />
        </com.google.android.material.textfield.TextInputLayout>

        <View style="@style/Widget.TravelApp.View.Divider"
            app:layout_constraintTop_toBottomOf="@id/tilEmail" />

        <TextView
            android:id="@+id/tvPasswordLabel"
            style="@style/Widget.TravelApp.TextView.InputLabel"
            android:text="MOT DE PASSE"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tilEmail"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPassword"
            style="@style/Widget.TravelApp.TextInputLayout.Line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:passwordToggleEnabled="true"
            app:layout_constraintTop_toBottomOf="@id/tvPasswordLabel">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPassword"
                style="@style/Widget.TravelApp.TextInputEditText.Line"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="••••••••"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <View style="@style/Widget.TravelApp.View.Divider"
            app:layout_constraintTop_toBottomOf="@id/tilPassword" />

        <TextView
            android:id="@+id/tvConfirmPasswordLabel"
            style="@style/Widget.TravelApp.TextView.InputLabel"
            android:text="CONFIRMER MOT DE PASSE"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/tilPassword"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilConfirmPassword"
            style="@style/Widget.TravelApp.TextInputLayout.Line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:passwordToggleEnabled="true"
            app:layout_constraintTop_toBottomOf="@id/tvConfirmPasswordLabel">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etConfirmPassword"
                style="@style/Widget.TravelApp.TextInputEditText.Line"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="••••••••"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <View style="@style/Widget.TravelApp.View.Divider"
            app:layout_constraintTop_toBottomOf="@id/tilConfirmPassword" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpdate"
            style="@style/Widget.TravelApp.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Modifier"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tilConfirmPassword" />

        <TextView
            android:id="@+id/tvDeleteAccount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Supprimer mon compte"
            android:textColor="#EF4444"
            android:textStyle="bold"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnUpdate"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>