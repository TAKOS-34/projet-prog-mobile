<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <ImageView
            android:id="@+id/btnBack"
            style="@style/Widget.TravelApp.Icon.Back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvFollowingTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/notif_following_title"
            android:textAppearance="@style/TextAppearance.TravelApp.HeadlineLarge"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvGroupsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/notif_following_groups"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
            android:textColor="@color/text_hint"
            app:layout_constraintTop_toBottomOf="@id/tvFollowingTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvGroupsEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/notif_following_empty_groups"
            android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvGroupsHeader"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGroupsFollowing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/tvGroupsHeader"
            tools:listitem="@layout/item_following" />

        <TextView
            android:id="@+id/tvUsersHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/notif_following_users"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
            android:textColor="@color/text_hint"
            app:layout_constraintTop_toBottomOf="@id/rvGroupsFollowing"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvUsersEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/notif_following_empty_users"
            android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvUsersHeader"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvUsersFollowing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/tvUsersHeader"
            tools:listitem="@layout/item_following" />

        <TextView
            android:id="@+id/tvTagsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/notif_following_tags"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
            android:textColor="@color/text_hint"
            app:layout_constraintTop_toBottomOf="@id/rvUsersFollowing"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvTagsEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/notif_following_empty_tags"
            android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvTagsHeader"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvTagsFollowing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/tvTagsHeader"
            tools:listitem="@layout/item_following" />

        <TextView
            android:id="@+id/tvLocalisationsHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/notif_following_localisations"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
            android:textColor="@color/text_hint"
            app:layout_constraintTop_toBottomOf="@id/rvTagsFollowing"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvLocalisationsEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/notif_following_empty_localisations"
            android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
            android:textColor="@color/text_secondary"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvLocalisationsHeader"
            app:layout_constraintStart_toStartOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLocalisationsFollowing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:nestedScrollingEnabled="false"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            app:layout_constraintTop_toBottomOf="@id/tvLocalisationsHeader"
            tools:listitem="@layout/item_following" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
