<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="10dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivFollowingAvatar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:scaleType="centerCrop"
        android:background="@color/surface_variant"
        app:shapeAppearanceOverlay="@style/Widget.TravelApp.Avatar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:src="@tools:sample/avatars" />

    <TextView
        android:id="@+id/tvFollowingName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textAppearance="@style/TextAppearance.TravelApp.TitleMedium"
        app:layout_constraintTop_toTopOf="@id/ivFollowingAvatar"
        app:layout_constraintBottom_toBottomOf="@id/ivFollowingAvatar"
        app:layout_constraintStart_toEndOf="@id/ivFollowingAvatar"
        app:layout_constraintEnd_toStartOf="@id/btnUnfollow"
        tools:text="takos34" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnUnfollow"
        style="@style/Widget.TravelApp.Button.Outlined"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="0dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:textSize="12sp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/notif_following_unfollow"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
