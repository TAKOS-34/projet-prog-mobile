<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <View
            android:id="@+id/viewBanner"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@color/primary"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProfileCover"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginTop="80dp"
            android:padding="4dp"
            android:background="@color/background"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/Widget.TravelApp.Avatar"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:src="@tools:sample/avatars" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabEditAvatar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fabSize="mini"
            app:backgroundTint="@color/primary"
            app:tint="@android:color/white"
            android:src="@android:drawable/ic_menu_edit"
            app:layout_constraintBottom_toBottomOf="@id/ivProfileCover"
            app:layout_constraintEnd_toEndOf="@id/ivProfileCover" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveAvatar"
            style="@style/Widget.TravelApp.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/btn_save_avatar"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/ivProfileCover"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvProfileName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textAppearance="@style/TextAppearance.TravelApp.HeadlineMedium"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/btnSaveAvatar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Username" />

        <TextView
            android:id="@+id/tvProfileBio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/tvProfileName"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="user@email.com" />

        <TextView
            android:id="@+id/tvMemberSince"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
            android:textColor="@color/text_hint"
            app:layout_constraintTop_toBottomOf="@id/tvProfileBio"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Membre depuis le 21/04/2026" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStats"
            style="@style/Widget.TravelApp.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvMemberSince">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingVertical="12dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvNbPosts"
                        style="@style/Widget.TravelApp.TextView.StatNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="1" />
                    <TextView
                        style="@style/Widget.TravelApp.TextView.StatLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_stat_posts" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:background="@color/divider"
                    android:layout_marginVertical="8dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvNbGroups"
                        style="@style/Widget.TravelApp.TextView.StatNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        tools:text="0" />
                    <TextView
                        style="@style/Widget.TravelApp.TextView.StatLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/profile_stat_groups" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditProfile"
            style="@style/Widget.TravelApp.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="32dp"
            android:text="@string/edit_profile"
            app:layout_constraintTop_toBottomOf="@id/cardStats" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSessions"
            style="@style/Widget.TravelApp.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:text="@string/btn_active_sessions"
            app:layout_constraintTop_toBottomOf="@id/btnEditProfile" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBookmarks"
            style="@style/Widget.TravelApp.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:text="@string/btn_bookmarks"
            app:layout_constraintTop_toBottomOf="@id/btnSessions" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/Widget.TravelApp.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:text="@string/profile_logout"
            app:layout_constraintTop_toBottomOf="@id/btnBookmarks" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
