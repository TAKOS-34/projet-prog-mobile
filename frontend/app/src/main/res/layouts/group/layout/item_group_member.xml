<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="10dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivMemberAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="centerCrop"
        android:background="@color/surface_variant"
        app:shapeAppearanceOverlay="@style/Widget.TravelApp.Avatar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:src="@tools:sample/avatars" />

    <TextView
        android:id="@+id/tvMemberUsername"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:maxLines="1"
        android:ellipsize="end"
        android:textAppearance="@style/TextAppearance.TravelApp.TitleMedium"
        app:layout_constraintTop_toTopOf="@id/ivMemberAvatar"
        app:layout_constraintBottom_toBottomOf="@id/ivMemberAvatar"
        app:layout_constraintStart_toEndOf="@id/ivMemberAvatar"
        app:layout_constraintEnd_toStartOf="@id/llMemberActions"
        tools:text="takos34" />

    <LinearLayout
        android:id="@+id/llMemberActions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnMemberMenu"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/ic_more_vert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            app:tint="@color/text_secondary"
            android:contentDescription="@null" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMemberDeban"
            style="@style/Widget.TravelApp.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/groups_admin_deban"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMemberAccept"
            style="@style/Widget.TravelApp.Button.Primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="0dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/groups_admin_accept"
            android:visibility="gone" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMemberRefuse"
            style="@style/Widget.TravelApp.Button.Outlined"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:minHeight="0dp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/groups_admin_refuse"
            android:visibility="gone" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
