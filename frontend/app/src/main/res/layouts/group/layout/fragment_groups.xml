<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:paddingHorizontal="24dp"
    android:paddingTop="32dp">

    <TextView
        android:id="@+id/tvGroupsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/groups_title"
        android:textAppearance="@style/TextAppearance.TravelApp.HeadlineLarge"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilGroupsSearch"
        style="@style/Widget.TravelApp.SearchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:startIconDrawable="@android:drawable/ic_menu_search"
        app:hintEnabled="false"
        app:layout_constraintTop_toBottomOf="@id/tvGroupsTitle">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etGroupsSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/groups_search_hint"
            android:paddingVertical="12dp"
            android:inputType="text"
            android:imeOptions="actionSearch" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/tvGroupsEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="@string/groups_empty"
        android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
        android:textColor="@color/text_secondary"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tilGroupsSearch"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvGroups"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="100dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/tilGroupsSearch"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_group" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabNewGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="80dp"
        android:src="@android:drawable/ic_menu_add"
        app:backgroundTint="@color/primary"
        app:tint="@android:color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:contentDescription="@string/create_group_title" />

</androidx.constraintlayout.widget.ConstraintLayout>
