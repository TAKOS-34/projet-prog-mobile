<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <ImageView
        android:id="@+id/btnBack"
        style="@style/Widget.TravelApp.Icon.Back"
        android:layout_marginStart="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/tgGroupTabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTabInfo"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/groups_tab_info"
            android:textAllCaps="false"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTabPosts"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/groups_tab_posts"
            android:textAllCaps="false"
            android:textSize="16sp" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollInfo"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tgGroupTabs"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingVertical="24dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivDetailAvatar"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:scaleType="centerCrop"
                android:background="@color/surface_variant"
                app:shapeAppearanceOverlay="@style/Widget.TravelApp.Avatar"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:src="@tools:sample/avatars" />

            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/fabEditGroupAvatar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_menu_edit"
                android:visibility="gone"
                app:fabSize="mini"
                app:backgroundTint="@color/primary"
                app:tint="@android:color/white"
                app:layout_constraintBottom_toBottomOf="@id/ivDetailAvatar"
                app:layout_constraintEnd_toEndOf="@id/ivDetailAvatar" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveGroupAvatar"
                style="@style/Widget.TravelApp.Button.Primary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/btn_save_avatar"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/ivDetailAvatar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/llDetailTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/btnSaveGroupAvatar"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <ImageView
                    android:id="@+id/ivDetailLock"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="8dp"
                    android:src="@drawable/ic_lock"
                    android:visibility="gone"
                    app:tint="@color/primary"
                    android:contentDescription="@string/groups_private_badge" />

                <TextView
                    android:id="@+id/tvDetailName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.TravelApp.HeadlineMedium"
                    tools:text="Voyageurs du monde" />

                <ImageView
                    android:id="@+id/btnFollowGroup"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    android:padding="4dp"
                    android:src="@drawable/ic_bell"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:visibility="gone"
                    app:tint="@color/text_secondary"
                    android:contentDescription="@null" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvDetailDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textAlignment="center"
                android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
                android:textColor="@color/text_secondary"
                app:layout_constraintTop_toBottomOf="@id/llDetailTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="Partage tes aventures autour du globe." />

            <LinearLayout
                android:id="@+id/llDetailMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvDetailDescription"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tvDetailMembers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
                    android:textColor="@color/text_hint"
                    tools:text="450 membres" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="6dp"
                    android:text=" · "
                    android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
                    android:textColor="@color/text_hint" />

                <TextView
                    android:id="@+id/tvDetailPosts"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
                    android:textColor="@color/text_hint"
                    tools:text="120 posts" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvDetailCreated"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
                android:textColor="@color/text_hint"
                app:layout_constraintTop_toBottomOf="@id/llDetailMeta"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="Créé le 03/01/2024" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewMembers"
                style="@style/Widget.TravelApp.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/groups_view_members"
                app:layout_constraintTop_toBottomOf="@id/tvDetailCreated" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnJoinGroupDetail"
                style="@style/Widget.TravelApp.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/btn_join_group"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/btnViewMembers" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewBanned"
                style="@style/Widget.TravelApp.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/groups_admin_banned_btn"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/btnViewMembers" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewRequests"
                style="@style/Widget.TravelApp.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/groups_admin_requests_btn"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/btnViewBanned" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditGroup"
                style="@style/Widget.TravelApp.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/groups_admin_edit_btn"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/btnViewRequests" />

            <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDeleteGroup"
                    style="@style/Widget.TravelApp.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/groups_admin_delete_btn"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/btnEditGroup" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnQuitGroup"
                style="@style/Widget.TravelApp.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/groups_quit_btn"
                android:visibility="gone"
                app:layout_constraintTop_toBottomOf="@id/btnDeleteGroup" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvGroupPosts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="16dp"
        android:paddingBottom="100dp"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintTop_toBottomOf="@id/tgGroupTabs"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_post" />

</androidx.constraintlayout.widget.ConstraintLayout>
