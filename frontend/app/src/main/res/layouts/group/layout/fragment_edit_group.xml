<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp">

        <ImageView
            android:id="@+id/btnBack"
            style="@style/Widget.TravelApp.Icon.Back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvEditGroupTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/groups_edit_title"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.TravelApp.HeadlineMedium"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvEditGroupSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/groups_edit_subtitle"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/tvEditGroupTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvNameLabel"
            style="@style/Widget.TravelApp.TextView.InputLabel"
            android:text="@string/label_group_name"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/tvEditGroupSubtitle"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilGroupName"
            style="@style/Widget.TravelApp.TextInputLayout.Line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:counterMaxLength="32"
            app:counterEnabled="true"
            app:layout_constraintTop_toBottomOf="@id/tvNameLabel">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etGroupName"
                style="@style/Widget.TravelApp.TextInputEditText.Line"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLength="32"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <View style="@style/Widget.TravelApp.View.Divider"
            android:id="@+id/divName"
            app:layout_constraintTop_toBottomOf="@id/tilGroupName" />

        <TextView
            android:id="@+id/tvDescriptionLabel"
            style="@style/Widget.TravelApp.TextView.InputLabel"
            android:text="@string/label_group_description"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/divName"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilGroupDescription"
            style="@style/Widget.TravelApp.TextInputLayout.Line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:counterMaxLength="280"
            app:counterEnabled="true"
            app:layout_constraintTop_toBottomOf="@id/tvDescriptionLabel">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etGroupDescription"
                style="@style/Widget.TravelApp.TextInputEditText.Line"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxLength="280"
                android:inputType="textMultiLine"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <View
            android:id="@+id/divDescription"
            style="@style/Widget.TravelApp.View.Divider"
            app:layout_constraintTop_toBottomOf="@id/tilGroupDescription" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchGroupPrivate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/label_group_private"
            android:textAppearance="@style/TextAppearance.TravelApp.TitleMedium"
            app:layout_constraintTop_toBottomOf="@id/divDescription" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUpdateGroup"
            style="@style/Widget.TravelApp.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            android:text="@string/btn_update_profile"
            app:layout_constraintTop_toBottomOf="@id/switchGroupPrivate"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
