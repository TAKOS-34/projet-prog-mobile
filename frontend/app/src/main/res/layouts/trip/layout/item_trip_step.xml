<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="20dp">

    <androidx.constraintlayout.widget.Guideline
            android:id="@+id/glTimeline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_begin="11dp" />

    <!-- START POINT (position 0 only) -->
    <View
        android:id="@+id/vStartDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_step_dot"
        app:layout_constraintStart_toStartOf="@id/glTimeline"
        app:layout_constraintEnd_toEndOf="@id/glTimeline"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvStartLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
        android:textColor="@color/text_secondary"
        app:layout_constraintBottom_toBottomOf="@id/vStartDot"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/glTimeline"
        app:layout_constraintTop_toTopOf="@id/vStartDot"
        tools:text="Paris" />

    <!-- CONNECTOR (always visible, snaps to top when vStartDot is GONE) -->
    <ImageView
        android:id="@+id/ivConnector"
        android:layout_width="2dp"
        android:layout_height="36dp"
        android:layout_marginStart="-1dp"
        android:scaleType="fitXY"
        android:src="@drawable/vd_dotted_line_vertical"
        app:layout_constraintStart_toStartOf="@id/glTimeline"
        app:layout_constraintTop_toBottomOf="@id/vStartDot"
        app:layout_goneMarginTop="0dp" />

    <TextView
        android:id="@+id/tvTravelTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
        android:textColor="@color/text_hint"
        app:layout_constraintBottom_toBottomOf="@id/ivConnector"
        app:layout_constraintStart_toEndOf="@id/glTimeline"
        app:layout_constraintTop_toTopOf="@id/ivConnector"
        tools:text="13 min" />

    <ImageView
        android:id="@+id/ivTravelTrust"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginStart="4dp"
        android:src="@drawable/ic_check_small"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/tvTravelTime"
        app:layout_constraintStart_toEndOf="@id/tvTravelTime"
        app:layout_constraintTop_toTopOf="@id/tvTravelTime"
        app:tint="@color/success"
        tools:visibility="visible" />

    <!-- DESTINATION POINT -->
    <TextView
        android:id="@+id/vDot"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginStart="-11dp"
        android:background="@drawable/bg_step_dot"
        android:gravity="center"
        android:includeFontPadding="false"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/glTimeline"
        app:layout_constraintTop_toBottomOf="@id/ivConnector"
        tools:text="1" />

    <View
        android:id="@+id/vBottomLine"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:layout_marginStart="-1dp"
        android:background="@color/divider"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/glTimeline"
        app:layout_constraintTop_toBottomOf="@id/vDot" />

    <TextView
        android:id="@+id/tvStepTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:textAppearance="@style/TextAppearance.TravelApp.TitleMedium"
        app:layout_constraintEnd_toStartOf="@id/ivStepImage"
        app:layout_constraintStart_toEndOf="@id/glTimeline"
        app:layout_constraintTop_toTopOf="@id/vDot"
        tools:text="Cimetière Marin" />

    <LinearLayout
        android:id="@+id/llStepLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="@id/tvStepTitle"
        app:layout_constraintStart_toStartOf="@id/tvStepTitle"
        app:layout_constraintTop_toBottomOf="@id/tvStepTitle">

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_location"
            app:tint="@color/text_hint" />

        <TextView
            android:id="@+id/tvStepLocation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
            android:textColor="@color/text_secondary"
            tools:text="Sète" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llStepMeta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/tvStepTitle"
        app:layout_constraintStart_toStartOf="@id/tvStepTitle"
        app:layout_constraintTop_toBottomOf="@id/llStepLocation">

        <TextView
            android:id="@+id/tvStepType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_group_badge"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
            android:textColor="@color/primary"
            tools:text="Panorama" />

        <TextView
            android:id="@+id/tvPriceSeparator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="6dp"
            android:text="·"
            android:textColor="@color/text_hint" />

        <ImageView
            android:id="@+id/ivPriceIcon"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_ticket"
            app:tint="#10B981" />

        <TextView
            android:id="@+id/tvStepPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
            android:textColor="#10B981"
            tools:text="0-10€" />

        <TextView
            android:id="@+id/tvDurationSeparator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="6dp"
            android:text="·"
            android:textColor="@color/text_hint" />

        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_clock"
            app:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/tvStepVisitDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
            tools:text="30 min" />

        <ImageView
            android:id="@+id/ivVisitTrust"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_marginStart="2dp"
            android:src="@drawable/ic_check_small"
            android:visibility="gone"
            app:tint="@color/success"
            tools:visibility="visible" />
    </LinearLayout>

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivStepImage"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.TravelApp.Medium"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvStepTitle"
        tools:src="@tools:sample/backgrounds/scenic" />

</androidx.constraintlayout.widget.ConstraintLayout>
