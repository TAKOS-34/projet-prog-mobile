<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.TravelApp.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginBottom="16dp"
    android:clickable="true"
    android:focusable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/ivTripCover"
            android:layout_width="match_parent"
            android:layout_height="170dp"
            android:scaleType="centerCrop"
            android:background="@color/surface_variant"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvWeatherBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:background="@drawable/bg_weather_badge"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:includeFontPadding="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="☀️ 19°C" />

        <TextView
            android:id="@+id/tvTripIndex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:background="@color/primary"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:textColor="@color/on_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:includeFontPadding="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            tools:text="Itinéraire 1" />

        <LinearLayout
            android:id="@+id/llTripStats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="4dp"
            app:layout_constraintTop_toBottomOf="@id/ivTripCover"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/ivTripArrow">

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/ic_clock"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvTripDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
                tools:text="4h30" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:text="·"
                android:textColor="@color/text_hint" />

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/ic_ticket"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvTripCost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
                tools:text="20 €" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:text="·"
                android:textColor="@color/text_hint" />

            <ImageView
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/ic_location"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvTripSteps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
                tools:text="4 étapes" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/llTripSuggestExtra"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingBottom="4dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/llTripStats"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:id="@+id/ivTripSuggestDifficulty"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/ic_bolt"
                android:visibility="gone"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvTripSuggestDifficulty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvTripSuggestAscentSep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:text="·"
                android:textColor="@color/text_hint"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ivTripSuggestAscent"
                android:layout_width="15dp"
                android:layout_height="15dp"
                android:src="@drawable/ic_arrow_up"
                android:visibility="gone"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/tvTripSuggestAscent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
                android:visibility="gone" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivTripArrow"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginEnd="16dp"
            android:src="@drawable/ic_chevron_down"
            android:rotation="-90"
            app:tint="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/ivTripCover"
            app:layout_constraintBottom_toBottomOf="@id/llTripStats"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvFirstLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="14dp"
            android:layout_marginTop="2dp"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/llTripSuggestExtra"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Cimetière marin → Plage de la corniche → ..." />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
