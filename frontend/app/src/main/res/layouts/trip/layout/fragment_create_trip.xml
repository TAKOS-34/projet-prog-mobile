<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp">

        <ImageView
            android:id="@+id/btnBack"
            style="@style/Widget.TravelApp.Icon.Back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvTripTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/trip_form_title"
            android:textAppearance="@style/TextAppearance.TravelApp.HeadlineLarge"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvTripSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/trip_form_subtitle"
            android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
            android:textColor="@color/text_hint"
            app:layout_constraintTop_toBottomOf="@id/tvTripTitle"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilTripCity"
            style="@style/Widget.TravelApp.SearchBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:startIconDrawable="@drawable/ic_location"
            app:hintEnabled="false"
            app:layout_constraintTop_toBottomOf="@id/tvTripSubtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etTripCity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/trip_city_hint"
                android:inputType="textCapSentences"
                android:imeOptions="actionDone"
                android:paddingVertical="12dp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgCitySuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tilTripCity"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvTypesLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/trip_types_label"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelLarge"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/cgCitySuggestions"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/cgPostTypes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvTypesLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvBudgetLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelLarge"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/cgPostTypes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvBudgetValue"
            tools:text="@string/trip_budget_label" />

        <TextView
            android:id="@+id/tvBudgetValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelLarge"
            android:textColor="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/cgPostTypes"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="200 €" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderBudget"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:valueFrom="0"
            android:valueTo="2000"
            android:stepSize="1"
            android:value="200"
            app:labelBehavior="gone"
            app:layout_constraintTop_toBottomOf="@id/tvBudgetLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvTimeLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelLarge"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/sliderBudget"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tvTimeValue"
            tools:text="@string/trip_time_label" />

        <TextView
            android:id="@+id/tvTimeValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelLarge"
            android:textColor="@color/primary"
            app:layout_constraintTop_toBottomOf="@id/sliderBudget"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="6h" />

        <com.google.android.material.slider.Slider
            android:id="@+id/sliderTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:valueFrom="1"
            android:valueTo="12"
            android:stepSize="1"
            android:value="3"
            app:labelBehavior="gone"
            app:layout_constraintTop_toBottomOf="@id/tvTimeLabel"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitTrip"
            style="@style/Widget.TravelApp.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/trip_submit"
            app:layout_constraintTop_toBottomOf="@id/sliderTime"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
