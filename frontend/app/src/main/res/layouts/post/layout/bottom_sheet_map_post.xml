<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/surface"
    android:paddingBottom="24dp">

    <View
        android:id="@+id/dragHandle"
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginTop="12dp"
        android:background="@color/divider"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivMapPostImage"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="16dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.TravelApp.Medium"
        app:layout_constraintTop_toBottomOf="@id/dragHandle"
        tools:src="@tools:sample/backgrounds/scenic" />

    <TextView
        android:id="@+id/tvMapPostTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:textAppearance="@style/TextAppearance.TravelApp.TitleMedium"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/ivMapPostImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Vue panoramique depuis le Pic du Midi" />

    <TextView
        android:id="@+id/tvMapPostMeta"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="16dp"
        android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
        android:textColor="@color/text_hint"
        app:layout_constraintTop_toBottomOf="@id/tvMapPostTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Par takos34 · Panorama" />

    <ImageView
        android:id="@+id/ivMapPostLocation"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        android:src="@drawable/ic_location"
        app:tint="@color/text_secondary"
        android:contentDescription="@null"
        app:layout_constraintTop_toBottomOf="@id/tvMapPostMeta"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvMapPostLocation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="16dp"
        android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
        android:textColor="@color/text_secondary"
        app:layout_constraintTop_toTopOf="@id/ivMapPostLocation"
        app:layout_constraintBottom_toBottomOf="@id/ivMapPostLocation"
        app:layout_constraintStart_toEndOf="@id/ivMapPostLocation"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Hautes-Pyrénées, France" />

    <LinearLayout
        android:id="@+id/llMapPostStats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/ivMapPostLocation"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_like"
            app:tint="@color/text_secondary"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tvMapPostLikes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
            android:textColor="@color/text_secondary"
            tools:text="12" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_comment"
            app:tint="@color/text_secondary"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/tvMapPostComments"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
            android:textColor="@color/text_secondary"
            tools:text="3" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
