<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/clCommentRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivCommentAvatar"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:scaleType="centerCrop"
        app:shapeAppearanceOverlay="@style/Widget.TravelApp.Avatar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@tools:sample/avatars" />

    <TextView
        android:id="@+id/tvCommentUsername"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:textAppearance="@style/TextAppearance.TravelApp.TitleMedium"
        android:textSize="13sp"
        app:layout_constraintTop_toTopOf="@id/ivCommentAvatar"
        app:layout_constraintStart_toEndOf="@id/ivCommentAvatar"
        app:layout_constraintEnd_toStartOf="@id/btnEditComment"
        tools:text="username" />

    <TextView
        android:id="@+id/tvCommentDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        app:layout_constraintTop_toBottomOf="@id/tvCommentUsername"
        app:layout_constraintStart_toStartOf="@id/tvCommentUsername"
        tools:text="il y a 2h" />

    <TextView
        android:id="@+id/tvEditedLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
        android:textColor="@color/text_hint"
        android:textSize="11sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/tvCommentDate"
        app:layout_constraintStart_toEndOf="@id/tvCommentDate"
        tools:text="(modifié le 12/03/26, 16:00)"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/btnEditComment"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:padding="4dp"
        android:src="@android:drawable/ic_menu_edit"
        app:tint="@color/text_secondary"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnDeleteComment"
        tools:visibility="visible" />

    <ImageView
        android:id="@+id/btnDeleteComment"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:padding="4dp"
        android:src="@android:drawable/ic_menu_delete"
        app:tint="@color/error"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@id/llLikeComment"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tvCommentContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="12dp"
        android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
        android:textSize="14sp"
        app:layout_constraintTop_toBottomOf="@id/tvCommentDate"
        app:layout_constraintStart_toStartOf="@id/tvCommentUsername"
        app:layout_constraintEnd_toStartOf="@id/llLikeComment"
        tools:text="C'est un super post !" />

    <LinearLayout
        android:id="@+id/llEditContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvCommentDate"
        app:layout_constraintStart_toStartOf="@id/tvCommentUsername"
        app:layout_constraintEnd_toStartOf="@id/llLikeComment">

        <EditText
            android:id="@+id/etEditComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:inputType="textMultiLine"
            android:padding="4dp"
            android:background="@drawable/bg_bottom_nav" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnSaveEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingVertical="8dp"
                android:text="Enregistrer"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/btnCancelEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:paddingVertical="8dp"
                android:text="@string/cancel"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:textSize="12sp" />

        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/llLikeComment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/btnLikeComment"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_like"
            app:tint="@color/text_secondary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/tvCommentLikeCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            tools:text="12" />
    </LinearLayout>

    <TextView
            android:id="@+id/tvShowReplies"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="16dp"
            android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tvCommentContent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@id/btnReplyComment"
            tools:text="-- Afficher les 3 réponses"
            tools:visibility="visible" />

    <TextView
        android:id="@+id/btnReplyComment"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/comment_answer"
        android:textAppearance="@style/TextAppearance.TravelApp.LabelMedium"
        android:textColor="@color/text_secondary"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvCommentContent"
        app:layout_constraintStart_toStartOf="@id/tvCommentUsername"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
