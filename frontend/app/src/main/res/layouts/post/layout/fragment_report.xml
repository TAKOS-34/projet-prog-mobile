<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp">

        <ImageView
            android:id="@+id/btnBack"
            style="@style/Widget.TravelApp.Icon.Back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/tvReportTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/report_title"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.TravelApp.HeadlineMedium"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvReportSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/report_subtitle"
            android:textAlignment="center"
            android:textAppearance="@style/TextAppearance.TravelApp.BodyMedium"
            android:textColor="@color/text_secondary"
            app:layout_constraintTop_toBottomOf="@id/tvReportTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <RadioGroup
            android:id="@+id/rgReportReasons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/tvReportSubtitle">

            <RadioButton
                android:id="@+id/rbInappropriate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/report_reason_inappropriate"
                android:textAppearance="@style/TextAppearance.TravelApp.BodyLarge"
                android:paddingVertical="8dp" />

            <RadioButton
                android:id="@+id/rbWrongLoc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/report_reason_wrong_loc"
                android:textAppearance="@style/TextAppearance.TravelApp.BodyLarge"
                android:paddingVertical="8dp" />

            <RadioButton
                android:id="@+id/rbSpam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/report_reason_spam"
                android:textAppearance="@style/TextAppearance.TravelApp.BodyLarge"
                android:paddingVertical="8dp" />

            <RadioButton
                android:id="@+id/rbPrivacy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/report_reason_privacy"
                android:textAppearance="@style/TextAppearance.TravelApp.BodyLarge"
                android:paddingVertical="8dp" />

            <RadioButton
                android:id="@+id/rbDangerous"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/report_reason_dangerous"
                android:textAppearance="@style/TextAppearance.TravelApp.BodyLarge"
                android:paddingVertical="8dp" />

            <RadioButton
                android:id="@+id/rbOther"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/report_reason_other"
                android:textAppearance="@style/TextAppearance.TravelApp.BodyLarge"
                android:paddingVertical="8dp" />
        </RadioGroup>

        <TextView
            android:id="@+id/tvDetailsLabel"
            style="@style/Widget.TravelApp.TextView.InputLabel"
            android:text="@string/label_report_details"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toBottomOf="@id/rgReportReasons"
            app:layout_constraintStart_toStartOf="parent" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDetails"
            style="@style/Widget.TravelApp.TextInputLayout.Line"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/tvDetailsLabel">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDetails"
                style="@style/Widget.TravelApp.TextInputEditText.Line"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:maxLength="300" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitReport"
            style="@style/Widget.TravelApp.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_submit_report"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/tilDetails"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginBottom="24dp"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
